  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<align=center><b><color=#0A3625><size=120%>INSTRUCCIONES ECOE</size></color></b>\r\n<size=85%><color=#333333>Estaci\xF3n
    de Evaluaci\xF3n Cl\xEDnica</color></size></align>\r\n<color=#999999>__________________________________________________</color>\r\n\r\n<color=#000000><b>1.
    FASE PR\xC1CTICA (CONSULTA 1)</b>\r\n\u2022 Entra a la <b><color=#0A3625>Consulta
    N\xBA 1</color></b> y analiza la marcha del paciente.\r\n\u2022 Revisa su expediente
    y selecciona el diagn\xF3stico en la hoja de respuestas.\r\n\u2022 Pulsa <b><color=#0A3625>Entregar
    Examen</color></b> para ver si eres <color=#15803D><b>APTO</b></color> o <color=#B91C1C><b>NO
    APTO</b></color>.\r\n\r\n<color=#999999>__________________________________________________</color>\r\n\r\n<b>2.
    FASE TE\xD3RICA (SALA DE ESPERA)</b>\r\n\u2022 Dir\xEDgete a la <b><color=#0A3625>Sala
    de Espera</color></b> para iniciar el test.\r\n\u2022 Responde las <b>10 preguntas
    te\xF3ricas</b> y entrega la plantilla.\r\n\r\n<color=#999999>__________________________________________________</color>\r\n\r\n<b>3.
    CALIFICACI\xD3N FINAL</b>\r\n\u2022 Al completar ambas fases, ver\xE1s tu nota
    global de <color=#15803D><b>APROBADO</b></color> o <color=#B91C1C><b>SUSPENDIDO</b></color>.</color>"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 15bf712043727264fb59510edc2deb9d, type: 2}
